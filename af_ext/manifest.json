{
	"manifest_version": 3,
	"name": "AutoFill Extension",
	"version": "1.0.0",
	"description": "Preenche formularios automaticamente com dados salvos localmente.",
	"permissions": ["storage", "activeTab"],
	"host_permissions": ["<all_urls>"],
	"action": {
		"default_title": "AutoFill",
		"default_popup": "popup.html"
	},
	"browser_specific_settings": {
		"gecko": {
			"id": "autofill.extension@example.com",
			"strict_min_version": "109.0"
		}
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"all_frames": true,
			"js": [
				"shared/contracts.js",
				"shared/constants.js",
				"core/text-core.js",
				"core/autofill-core.js",
				"content.js",
				"autofill-debug.js"
			],
			"run_at": "document_idle"
		}
	]
}
