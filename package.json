{
  "name": "autofill-extension",
  "version": "1.1.0",
  "private": true,
  "description": "Autofill browser extension built with TypeScript",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -f af_ext/content.js af_ext/popup.js af_ext/autofill-debug.js af_ext/*.js.map"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}